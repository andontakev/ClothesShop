@{
    ViewData["Title"] = "PresAndo – Начало";
}

<!-- HERO SECTION -->
<header class="hero">
    <nav class="navbar">
        <div class="logo">PresAndo</div>
        <ul class="nav-links">
            <li><a href="/">Начало</a></li>
            <li><a href="#">Жени</a></li>
            <li><a href="#">Мъже</a></li>
            <li><a href="#">Аксесоари</a></li>
            <li><a href="/Home/Privacy">Поверителност</a></li>
        </ul>
    </nav>

    <div class="hero-content">
        <h1>Стилът започва от PresAndo</h1>
        <p>Открий най-новите модни тенденции за сезона</p>
        <a href="#" class="btn-main">Разгледай колекцията</a>
    </div>
</header>

<!-- PRODUCTS -->
<section class="products-section">
    <h2>Най-продавани продукти</h2>

    <div class="products">
        <div class="product-card">
            <img src="~/images/leather-jacket.jpg" alt="Яке">
            <h3>Кожено яке</h3>
            <p>89.99 евро</p>
            <button>Купи</button>
        </div>

        <div class="product-card">
            <img src="~/images/white-tshirt.png" alt="Тениска">
            <h3>Мъжка тениска</h3>
            <p>29.99 евро</p>
            <button>Купи</button>
        </div>

        <div class="product-card">
            <img src="~/images/dress.jpg" alt="Рокля">
            <h3>Дамска рокля</h3>
            <p>59.99 евро</p>
            <button>Купи</button>
        </div>
    </div>
</section>

<!-- BANNER -->
<section class="banner">
    <h2>Нова колекция Пролет 2026</h2>
    <a href="#" class="btn-main">Виж повече</a>
</section>
