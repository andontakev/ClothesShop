<section class="sale" id="fashion">
    <div class="section__container sale__container">
        <div class="sale__image">
            <img src="assets/sale.png" alt="sale" />
        </div>
        <div class="sale__content">
            <h2><span>СПЕЦИАЛНО</span><br />НАМАЛЕНИЕ</h2>
            <p>
                При покупка над 100€ получаваш 30% ваучер за следваща поръчка.
            </p>
            <h4>1 февруари - 28 февруари 2026</h4>
            <p>*Важи при условия</p>
            <div class="sale__btn">
                <a asp-controller="Products" asp-action="Index" class="btn">Пазарувай сега</a>
            </div>
        </div>
    </div>
</section>

<section class="section__container favourite__container" id="favourite">
