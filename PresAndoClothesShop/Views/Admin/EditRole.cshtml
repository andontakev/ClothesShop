@model PresAndoClothesShop.ViewModel.EditRoleViewModel

@{
    ViewData["Title"] = "Редактиране на роля";
}

<h1>Edit Role</h1>

<form method="post" class="row">
    <div class="mt-3 col-4">
        <div class="form-group row">
            <label asp-for="Id" class="col-form-label col-2"></label>
            <input asp-for="Id" class="form-control col-9 p-2" disabled style="font size: 0.9em" />
        </div>
        <div class="form-group row">
            <label asp-for="RoleName" class="col-form-label col-2"></label>
            <input asp-for="RoleName" class="form-control col-9 p-2" />
            <span asp-validation-for="RoleName" class="text-danger col-9 offset-2"></span>
        </div>
        @*<div asp-validation-summary="All" class="text-danger"></div>*@
        <div class="form-group">
            <a asp-action="ListAllRoles" class="btn btn-warning">Назад</a>
            <button type="submit" class="btn btn-success float-right mr-3">Запази промените</button>
        </div>
    </div>
    <div class="col-1"></div>
    <div class="col-5">
        <h3>Потребители с роля @Model.RoleName</h3>
        <table class="table table-striped col-8">
            <tr></tr>
            @if (Model.Users.Any())
            {
                foreach (var user in Model.Users.ToList())
                {
                    <tr>
                        <td class="form-label">@user</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td class="form-label">Няма потребители с роля @Model.RoleName</td>
                </tr>
            }
        </table>
        <div>
            <a asp-action="EditUsersInRole" asp-route-id="@Model.Id" class="btn btn-primary">Добави/Изтрий потребители с роля</a>
        </div>
    </div>
</form>
