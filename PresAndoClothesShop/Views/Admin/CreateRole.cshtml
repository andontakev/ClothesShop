@model PresAndoClothesShop.ViewModel.CreateRoleViewModel

@{
    ViewData["Title"] = "Добави роля";
}

<h1>Добави роля</h1>

<form asp-action="CreateRole" method="post" class="mt-3">
    <div class="form-group row">
        <label asp-for="RoleName" class="col-1 col-form-label"></label>
        <div>
            <input asp-for="RoleName" class="form-control" placeholder="Name"/>
            <span asp-validation-for="RoleName" class="text-danger"></span>
        </div>
    </div>
    <div>
        <button type="submit" class="btn btn-primary mt-2">Добави</button>
        <div>
            <a asp-action="ListAllRoles" class="btn btn-warning my-3">Назад</a>
        </div>
    </div>
</form>
