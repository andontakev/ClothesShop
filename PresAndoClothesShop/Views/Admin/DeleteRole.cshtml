@using Microsoft.AspNetCore.Identity
@model IdentityRole

<h3>Наистина ли искате да изтриете ролята "@Model.Name"?</h3>
<h6>Това действие е необратимо!</h6>
<div asp-validation-summary="All" class="text-danger"></div>
<form method="post" asp-action="ConfirmDelete" asp-route-id="@Model.Id" class="mt-3">
    <button type="submit" class="btn btn-danger">Изтрий</button>
    <div class="mt-2">
        <a asp-action="ListAllRoles" class="btn btn-warning">Отказ</a>
    </div>
</form>
