<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PresAndoClothesShop</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PresAndoClothesShop.styles.css" asp-append-version="true" />
</head>

<body>
    <header>
        <nav>
            <div class="nav__header">
                <div class="nav__logo">
                    <a href="#">PresAndo Clothes</a>
                </div>
                <div class="nav__menu__btn" id="menu-btn">
                    <i class="ri-menu-line"></i>
                </div>
            </div>
            <ul class="nav__links" id="nav-links">
                <li><a href="#catalogue">Catalogue</a></li>
                <li><a href="#fashion">Men</a></li>
                <li><a href="#favourite">Favourite</a></li>
                <li><a href="#lifestyle">Privacy</a></li>
                <li><a asp-area="Identity" asp-page="/Account/Register" class="register-link">Register</a></li>
                <li><a asp-area="Identity" asp-page="/Account/Login" class="login-link">Login</a></li>

            </ul>
        </nav>
       @*  <nav class="navbar navbar-expand-sm navbar-light main-nav">
            <div class="container-fluid">
                <a class="navbar-brand logo-text" asp-area="" asp-controller="Home" asp-action="Index">PresAndo</a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 nav-links-layout">
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Начало</a></li>
                        <li class="nav-item"><a class="nav-link" href="#">Жени</a></li>
                        <li class="nav-item"><a class="nav-link" href="#">Мъже</a></li>
                        <li class="nav-item"><a class="nav-link" href="#">Аксесоари</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Privacy">Поверителност</a></li>
                    </ul>

                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav> *@
    </header>


    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-custom">
        <div class="container">
            &copy; 2026 - PresAndoClothesShop
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
