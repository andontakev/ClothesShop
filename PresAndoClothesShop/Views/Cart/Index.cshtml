@model PresAndoClothesShop.Models.Cart

@{
    ViewData["Title"] = "Количка";
    var items = Model.CartItems ?? new List<PresAndoClothesShop.Models.CartItem>();
}

<h1>Твоята количка</h1>

@if (!items.Any())
{
    <div class="alert alert-info">Количката е празна.</div>
    <a class="btn btn-primary" asp-controller="Products" asp-action="Index">Разгледай продукти</a>
}
else
{
    <table class="table align-middle">
        <thead>
            <tr>
                <th>Снимка</th>
                <th>Продукт</th>
                <th>Цена</th>
                <th>Количество</th>
                <th>Междинна сума</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in items)
            {
                var productTotal = item.Product.Price * item.Quantity;
                <tr>
                    <td>
                        <img src="@item.Product.ImageUrl" alt="@item.Product.Name" style="width: 70px; height: 70px; object-fit: cover;" />
                    </td>
                    <td>@item.Product.Name</td>
                    <td>@item.Product.Price.ToString("C")</td>
                    <td>
                        <div class="d-flex gap-1">
                            <form asp-controller="Cart" asp-action="DecreaseQuantity" asp-route-id="@item.ProductId" method="post">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-outline-secondary btn-sm" type="submit">-</button>
                            </form>
                            <span class="px-2 py-1 border rounded">@item.Quantity</span>
                            <form asp-controller="Cart" asp-action="IncreaseQuantity" asp-route-id="@item.ProductId" method="post">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-outline-secondary btn-sm" type="submit">+</button>
                            </form>
                        </div>
                    </td>
                    <td>@productTotal.ToString("C")</td>
                    <td>
                        <form asp-controller="Cart" asp-action="RemoveFromCart" asp-route-id="@item.ProductId" method="post">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-danger btn-sm" type="submit">Премахни</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
        <tfoot>
            <tr>
                <td colspan="4" class="text-end"><strong>Общо</strong></td>
                <td><strong>@Model.GetCartTotal().ToString("C")</strong></td>
                <td></td>
            </tr>
        </tfoot>
    </table>

    <div class="d-flex gap-2">
        <form asp-controller="Cart" asp-action="ClearCart" method="post">
            @Html.AntiForgeryToken()
            <button class="btn btn-outline-danger" type="submit">Изчисти количката</button>
        </form>
        <a class="btn btn-primary" asp-controller="Products" asp-action="Index">Продължи пазаруването</a>
    </div>
}
