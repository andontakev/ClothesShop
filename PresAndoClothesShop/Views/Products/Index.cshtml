@model IEnumerable<PresAndoClothesShop.Models.Product>

@{
    ViewData["Title"] = "Продукти";
    var returnUrl = Context.Request.Path + Context.Request.QueryString;
    var isAdmin = User.IsInRole("Администратор");
}

<section class="products-page">
    <div class="products-header">
        <div>
            <h1>Продукти</h1>
            <p>Открий перфектната визия от PresAndo Clothes.</p>
        </div>
        @if (isAdmin)
        {
            <a class="shop-btn shop-btn-primary" asp-action="Create">
                <i class="ri-add-circle-line"></i>
                <span>Нов продукт</span>
            </a>
        }
    </div>

    <div class="products-grid">
        @foreach (var item in Model)
        {
            <article class="product-card">
                <div class="product-image-wrap">
                    <img src="@item.ImageUrl" alt="@item.Name" class="product-image" />
                    <span class="product-category">@item.Category?.Name</span>
                </div>

                <div class="product-body">
                    <h3>@item.Name</h3>
                    <p>@item.Description</p>
                    <div class="product-meta">
                        <span><i class="ri-ruler-line"></i> @item.Size</span>
                        <span><i class="ri-palette-line"></i> @item.Color</span>
                    </div>
                </div>

                <div class="product-footer">
                    <div class="product-price">@item.Price.ToString("C")</div>
                    <div class="product-actions">
                        <a class="icon-btn" asp-action="Details" asp-route-id="@item.Id" title="Детайли">
                            <i class="ri-eye-line"></i>
                        </a>
                        @if (isAdmin)
                        {
                            <a class="icon-btn" asp-action="Edit" asp-route-id="@item.Id" title="Редакция">
                                <i class="ri-edit-line"></i>
                            </a>
                            <a class="icon-btn icon-btn-danger" asp-action="Delete" asp-route-id="@item.Id" title="Изтриване">
                                <i class="ri-delete-bin-6-line"></i>
                            </a>
                        }
                        <form asp-controller="Cart" asp-action="AddToCart" asp-route-id="@item.Id" asp-route-returnUrl="@returnUrl" method="post">
                            @Html.AntiForgeryToken()
                            <button class="shop-btn shop-btn-dark" type="submit">
                                <i class="ri-shopping-bag-3-line"></i>
                                <span>Добави</span>
                            </button>
                        </form>
                    </div>
                </div>
            </article>
        }
    </div>
</section>
